<Window x:Class="WeldAdminPro.UI.Views.NewStockItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock Item"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="15">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="120"/>
			<ColumnDefinition Width="260"/>
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- ITEM CODE -->
		<TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Item Code"
                   VerticalAlignment="Center"/>

		<TextBox Grid.Row="0" Grid.Column="1"
                 Width="240"
                 Text="{Binding Item.ItemCode}"
                 IsReadOnly="{Binding IsEditMode}"/>

		<!-- CATEGORY -->
		<TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Category"
                   Margin="0,10,0,0"
                   VerticalAlignment="Center"/>

		<ComboBox Grid.Row="1" Grid.Column="1"
                  Margin="0,10,0,0"
                  Width="240"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding Item.Category}"/>

		<!-- DESCRIPTION -->
		<TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Description"
                   Margin="0,10,0,0"
                   VerticalAlignment="Center"/>

		<TextBox Grid.Row="2" Grid.Column="1"
                 Margin="0,10,0,0"
                 Width="240"
                 Text="{Binding Item.Description}"/>

		<!-- QUANTITY -->
		<TextBlock Grid.Row="3" Grid.Column="0"
                   Text="Quantity"
                   Margin="0,10,0,0"
                   VerticalAlignment="Center"/>

		<TextBox Grid.Row="3" Grid.Column="1"
                 Margin="0,10,0,0"
                 Width="100"
                 Text="{Binding Item.Quantity}"/>

		<!-- MIN LEVEL -->
		<TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Min Stock Level"
                   Margin="0,10,0,0"
                   VerticalAlignment="Center"/>

		<TextBox Grid.Row="4" Grid.Column="1"
                 Margin="0,10,0,0"
                 Width="100"
                 Text="{Binding Item.MinLevel}"/>

		<!-- MAX LEVEL -->
		<TextBlock Grid.Row="5" Grid.Column="0"
                   Text="Max Stock Level"
                   Margin="0,10,0,0"
                   VerticalAlignment="Center"/>

		<TextBox Grid.Row="5" Grid.Column="1"
                 Margin="0,10,0,0"
                 Width="100"
                 Text="{Binding Item.MaxLevel}"/>

		<!-- BUTTONS -->
		<StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

			<Button Content="Save"
                    Width="80"
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}"/>

			<Button Content="Cancel"
                    Width="80"
                    Command="{Binding CancelCommand}"/>
		</StackPanel>

	</Grid>
</Window>
